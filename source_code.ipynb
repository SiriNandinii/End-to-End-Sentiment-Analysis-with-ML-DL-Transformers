        "# -------------------------\n",
        "muted_colors = [\n",
        "    \"#6F9F95\",\n",
        "    \"#7F8FB0\",\n",
        "    \"#C08A86\",\n",
        "    \"#8FAF7A\",\n",
        "    \"#AFAF98\",\n",
        "    \"#8C7A8F\",\n",
        "    \"#C9925E\",\n",
